#include <iostream>
using namespace std;

int main() {
    int num, rev = 0, d;

    cout << "Enter an integer: ";
    cin >> num;

    while (num != 0) {
        d = num % 10;           
        rev = rev * 10 + d; 
        num /= 10;                    
    }

    cout << "Reversed number: " << rev << endl;

    return 0;
}
