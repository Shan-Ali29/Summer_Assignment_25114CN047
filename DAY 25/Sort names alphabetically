#include <iostream>
#include <cstring>
using namespace std;

int main()
{
    char name[5][20], temp[20];
    int i, j;

    cout << "Enter 5 names:\n";
    for (i = 0; i < 5; i++)
        cin >> name[i];

    for (i = 0; i < 4; i++)
    {
        for (j = i + 1; j < 5; j++)
        {
            if (strcmp(name[i], name[j]) > 0)
            {
                strcpy(temp, name[i]);
                strcpy(name[i], name[j]);
                strcpy(name[j], temp);
            }
        }
    }

    cout << "Names in alphabetical order:\n";
    for (i = 0; i < 5; i++)
        cout << name[i] << endl;

    return 0;
}
