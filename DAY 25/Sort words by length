#include <iostream>
#include <cstring>
using namespace std;

int main()
{
    char word[5][20], temp[20];
    int i, j;

    cout << "Enter 5 words:\n";
    for (i = 0; i < 5; i++)
        cin >> word[i];

    for (i = 0; i < 4; i++)
    {
        for (j = i + 1; j < 5; j++)
        {
            if (strlen(word[i]) > strlen(word[j]))
            {
                strcpy(temp, word[i]);
                strcpy(word[i], word[j]);
                strcpy(word[j], temp);
            }
        }
    }

    cout << "Words sorted by length:\n";
    for (i = 0; i < 5; i++)
        cout << word[i] << endl;

    return 0;
}
