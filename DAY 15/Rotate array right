#include <iostream>
using namespace std;

int main()
{
    int arr[10], last;

    cout << "Enter 10 elements of the array:\n";
    for(int i = 0; i < 10; i++)
    {
        cin >> arr[i];
    }

    last = arr[9];

    for(int i = 9; i > 0; i--)
    {
        arr[i] = arr[i - 1];
    }

    arr[0] = last;

    cout << "Array after right rotation:\n";
    for(int i = 0; i < 10; i++)
    {
        cout << arr[i] << " ";
    }

    return 0;
}
