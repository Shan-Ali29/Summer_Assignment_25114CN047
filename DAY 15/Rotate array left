#include <iostream>
using namespace std;

int main()
{
    int arr[10], first;

    cout << "Enter 10 elements of the array:\n";
    for(int i = 0; i < 10; i++)
    {
        cin >> arr[i];
    }

    first = arr[0];

    for(int i = 0; i < 9; i++)
    {
        arr[i] = arr[i + 1];
    }

    arr[9] = first;

    cout << "Array after left rotation:\n";
    for(int i = 0; i < 10; i++)
    {
        cout << arr[i] << " ";
    }

    return 0;
}
