#include <iostream>
using namespace std;

int main()
{
    int arr[10], temp[10];
    int j = 0;

    cout << "Enter 10 elements of the array:\n";
    for(int i = 0; i < 10; i++)
    {
        cin >> arr[i];
    }

    // First store non-zero elements
    for(int i = 0; i < 10; i++)
    {
        if(arr[i] != 0)
        {
            temp[j] = arr[i];
            j++;
        }
    }

    // Fill remaining positions with zero
    while(j < 10)
    {
        temp[j] = 0;
        j++;
    }

    cout << "Array after moving zeroes to end:\n";
    for(int i = 0; i < 10; i++)
    {
        cout << temp[i] << " ";
    }

    return 0;
}
