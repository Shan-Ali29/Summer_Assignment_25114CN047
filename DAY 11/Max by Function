#include <iostream>
using namespace std;
int maxN(int a,int b){
    if(a>b){
        return a;
    }
    if(b>a){
        return b;
    }
}
int main(){
    int a,b;
    cout<<"Enter two numbers:";
    cin>>a>>b;
    if(a>b || b>a){
        cout<<"The max number is="<<maxN(a,b);
    }
    else{
        cout<<"Both are equal";
    }
}
