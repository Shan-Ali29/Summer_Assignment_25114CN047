#include <iostream>
using namespace std;
int factorialN(int n){
    int fact=1;
    for(int i=1; i<=n; i++){
        fact=fact*i;
    }
    return fact;
}
int main(){
    int n,fact=1;
    cout<<"Enter the number:";
    cin>>n;
    if(n==0 || n==1){
        cout<<"The factorial is=1";

    }
    else{
        if(n>0){
            cout<<"The factorial is="<<factorialN(n);
        }
        else{
            cout<<"The factorial is not defined";
        }
    }
    return 0;
}
