#include <iostream>
using namespace std;

int main() {
    int n;
    cout << "Enter a number: ";
    cin >> n;

    int largestPrime = -1;

    // Divide out factors of 2
    while (n % 2 == 0) {
        largestPrime = 2;
        n /= 2;
    }

    for (int i = 3; i * i <= n; i += 2) {
        while (n % i == 0) {
            largestPrime = i;
            n /= i;
        }
    }

    if (n > 2) {
        largestPrime = n;
    }

    cout << "Largest Prime Factor = " << largestPrime << endl;

    return 0;
}
