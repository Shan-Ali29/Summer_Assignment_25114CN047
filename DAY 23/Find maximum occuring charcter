#include <iostream>
using namespace std;

int main()
{
    char str[100];
    int count[256] = {0};
    int i, max = 0;
    char ch;

    cout << "Enter a string: ";
    cin.getline(str, 100);

    for (i = 0; str[i] != '\0'; i++)
    {
        count[(int)str[i]]++;
    }

    for (i = 0; i < 256; i++)
    {
        if (count[i] > max)
        {
            max = count[i];
            ch = (char)i;
        }
    }

    cout << "Maximum occurring character: " << ch << endl;
    cout << "Frequency: " << max;

    return 0;
}
