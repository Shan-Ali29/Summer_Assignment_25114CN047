#include <iostream>
using namespace std;

int main()
{
    char str[100];
    int i, j;
    bool found;

    cout << "Enter a string: ";
    cin.getline(str, 100);

    for (i = 0; str[i] != '\0'; i++)
    {
        found = false;

        for (j = 0; str[j] != '\0'; j++)
        {
            if (i != j && str[i] == str[j])
            {
                found = true;
                break;
            }
        }

        if (!found)
        {
            cout << "First non-repeating character: " << str[i];
            return 0;
        }
    }

    cout << "No non-repeating character found.";

    return 0;
}
