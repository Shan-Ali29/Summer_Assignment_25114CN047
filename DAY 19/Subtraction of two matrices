#include <iostream>
using namespace std;

int main()
{
    int r, c;

    cout << "Enter number of rows and columns: ";
    cin >> r >> c;

    int a[r][c], b[r][c], sub[r][c];

    cout << "Enter elements of first matrix:\n";
    for(int i = 0; i < r; i++)
    {
        for(int j = 0; j < c; j++)
        {
            cin >> a[i][j];
        }
    }

    cout << "Enter elements of second matrix:\n";
    for(int i = 0; i < r; i++)
    {
        for(int j = 0; j < c; j++)
        {
            cin >> b[i][j];
        }
    }

    // Subtracting matrices
    for(int i = 0; i < r; i++)
    {
        for(int j = 0; j < c; j++)
        {
            sub[i][j] = a[i][j] - b[i][j];
        }
    }

    cout << "Difference of matrices is:\n";
    for(int i = 0; i < r; i++)
    {
        for(int j = 0; j < c; j++)
        {
            cout << sub[i][j] << " ";
        }
        cout << endl;
    }

    return 0;
}
