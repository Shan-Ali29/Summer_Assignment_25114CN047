#include <iostream>
using namespace std;

int main()
{
    int arr[10];

    cout << "Enter 10 elements of the array:\n";
    for(int i = 0; i < 10; i++)
    {
        cin >> arr[i];
    }

    int largest = arr[0];
    int secondLargest = arr[0];

    for(int i = 1; i < 10; i++)
    {
        if(arr[i] > largest)
        {
            secondLargest = largest;
            largest = arr[i];
        }
        else if(arr[i] > secondLargest && arr[i] != largest)
        {
            secondLargest = arr[i];
        }
    }

    cout << "Second Largest Element = " << secondLargest << endl;

    return 0;
}
