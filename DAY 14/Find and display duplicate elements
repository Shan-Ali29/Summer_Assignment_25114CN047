#include <iostream>
using namespace std;

int main()
{
    int arr[10];

    cout << "Enter 10 elements of the array:\n";
    for(int i = 0; i < 10; i++)
    {
        cin >> arr[i];
    }

    cout << "Duplicate elements are: ";

    for(int i = 0; i < 10; i++)
    {
        bool isDuplicate = false;

        for(int k = 0; k < i; k++)
        {
            if(arr[i] == arr[k])
            {
                isDuplicate = true;
                break;
            }
        }

        if(isDuplicate)
            continue;

        for(int j = i + 1; j < 10; j++)
        {
            if(arr[i] == arr[j])
            {
                cout << arr[i] << " ";
                break;
            }
        }
    }

    return 0;
}
