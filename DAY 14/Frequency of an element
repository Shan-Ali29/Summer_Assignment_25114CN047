#include <iostream>
using namespace std;

int main()
{
    int arr[10], key, count = 0;

    cout << "Enter 10 elements of the array:\n";
    for(int i = 0; i < 10; i++)
    {
        cin >> arr[i];
    }

    cout << "Enter the element whose frequency you want to find: ";
    cin >> key;

    for(int i = 0; i < 10; i++)
    {
        if(arr[i] == key)
        {
            count++;
        }
    }

    cout << "Frequency of " << key << " = " << count << endl;

    return 0;
}
