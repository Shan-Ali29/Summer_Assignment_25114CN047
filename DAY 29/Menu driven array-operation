#include <iostream>
using namespace std;

int main()
{
    int a[10], n, i, sum = 0, choice;

    cout << "Enter size of array: ";
    cin >> n;

    cout << "Enter array elements:\n";
    for(i = 0; i < n; i++)
        cin >> a[i];

    cout << "\n1. Display\n";
    cout << "2. Sum\n";
    cout << "3. Largest Element\n";
    cout << "Enter Choice: ";
    cin >> choice;

    switch(choice)
    {
        case 1:
            for(i = 0; i < n; i++)
                cout << a[i] << " ";
            break;

        case 2:
            for(i = 0; i < n; i++)
                sum += a[i];
            cout << "Sum = " << sum;
            break;

        case 3:
        {
            int max = a[0];
            for(i = 1; i < n; i++)
                if(a[i] > max)
                    max = a[i];

            cout << "Largest = " << max;
            break;
        }

        default:
            cout << "Invalid Choice";
    }

    return 0;
}
