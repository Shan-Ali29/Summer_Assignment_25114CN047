#include <iostream>
#include <cmath>
using namespace std;


int isArmstrong(int num)
{
    int originalNum = num;
    int sum = 0, digits = 0, temp;

  
    temp = num;
    while (temp > 0)
    {
        digits++;
        temp /= 10;
    }

  
    temp = num;
    while (temp > 0)
    {
        int digit = temp % 10;
        sum += pow(digit, digits);
        temp /= 10;
    }

    if (sum == originalNum)
        return 1;
    else
        return 0;
}

int main()
{
    int num;

    cout << "Enter a number: ";
    cin >> num;

    if (isArmstrong(num) == 1)
        cout << num << " is an Armstrong number.";
    else
        cout << num << " is not an Armstrong number.";

    return 0;
}
