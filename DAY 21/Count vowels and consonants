#include <iostream>
using namespace std;

int main()
{
    char str[100];
    int i = 0, vowels = 0, consonants = 0;

    cout << "Enter a string: ";
    cin.getline(str, 100);

    while (str[i] != '\0')
    {
        char ch = str[i];

        if (ch >= 'A' && ch <= 'Z')
            ch = ch + 32;

        if (ch >= 'a' && ch <= 'z')
        {
            if (ch == 'a' || ch == 'e' || ch == 'i' || ch == 'o' || ch == 'u')
                vowels++;
            else
                consonants++;
        }

        i++;
    }

    cout << "Vowels = " << vowels << endl;
    cout << "Consonants = " << consonants;

    return 0;
}
