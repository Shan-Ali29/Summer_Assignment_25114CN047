#include <iostream>
using namespace std;

int main()
{
    char str[100], temp;
    int i = 0, len = 0;

    cout << "Enter a string: ";
    cin.getline(str, 100);

    while (str[len] != '\0')
    {
        len++;
    }

    for (i = 0; i < len / 2; i++)
    {
        temp = str[i];
        str[i] = str[len - i - 1];
        str[len - i - 1] = temp;
    }

    cout << "Reversed string: " << str;

    return 0;
}
