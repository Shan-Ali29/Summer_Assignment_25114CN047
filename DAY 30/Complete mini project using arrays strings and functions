#include <iostream>
using namespace std;

int roll[5], marks[5];
char name[5][30];

void input()
{
    for(int i = 0; i < 5; i++)
    {
        cout << "\nEnter Roll No: ";
        cin >> roll[i];

        cout << "Enter Name: ";
        cin >> name[i];

        cout << "Enter Marks: ";
        cin >> marks[i];
    }
}

void display()
{
    cout << "\nStudent Records\n";

    for(int i = 0; i < 5; i++)
    {
        cout << "\nRoll No: " << roll[i];
        cout << "\nName: " << name[i];
        cout << "\nMarks: " << marks[i] << endl;
    }
}

int main()
{
    input();
    display();

    return 0;
}
