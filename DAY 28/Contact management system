#include <iostream>
using namespace std;

class Contact
{
    string name;
    string phone;

public:
    void getData()
    {
        cout << "Enter Name: ";
        cin >> name;
        cout << "Enter Phone Number: ";
        cin >> phone;
    }

    void display()
    {
        cout << "\nName: " << name;
        cout << "\nPhone Number: " << phone << endl;
    }
};

int main()
{
    Contact c;
    c.getData();
    c.display();
    return 0;
}
