#include <iostream>
using namespace std;

int main()
{
    char str[100];
    int i = 0, words = 1;

    cout << "Enter a sentence: ";
    cin.getline(str, 100);

    while (str[i] != '\0')
    {
        if (str[i] == ' ')
            words++;

        i++;
    }

    cout << "Number of words = " << words;

    return 0;
}
