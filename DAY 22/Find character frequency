#include <iostream>
using namespace std;

int main()
{
    char str[100], ch;
    int i = 0, count = 0;

    cout << "Enter a string: ";
    cin.getline(str, 100);

    cout << "Enter character to find frequency: ";
    cin >> ch;

    while (str[i] != '\0')
    {
        if (str[i] == ch)
            count++;

        i++;
    }

    cout << "Frequency of " << ch << " = " << count;

    return 0;
}
