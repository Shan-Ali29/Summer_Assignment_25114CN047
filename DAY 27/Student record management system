#include <iostream>
using namespace std;

int main()
{
    int roll;
    char name[50];
    float marks;

    cout << "Enter Roll Number: ";
    cin >> roll;

    cin.ignore();

    cout << "Enter Name: ";
    cin.getline(name, 50);

    cout << "Enter Marks: ";
    cin >> marks;

    cout << "\n----- Student Record -----\n";
    cout << "Roll Number : " << roll << endl;
    cout << "Name        : " << name << endl;
    cout << "Marks       : " << marks << endl;

    return 0;
}
