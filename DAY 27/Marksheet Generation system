#include <iostream>
using namespace std;

int main()
{
    char name[50];
    int m1, m2, m3, total;
    float percentage;

    cout << "Enter Student Name: ";
    cin.getline(name, 50);

    cout << "Enter Marks of 3 Subjects: ";
    cin >> m1 >> m2 >> m3;

    total = m1 + m2 + m3;
    percentage = total / 3.0;

    cout << "\n----- Marksheet -----\n";
    cout << "Name       : " << name << endl;
    cout << "Total Marks: " << total << endl;
    cout << "Percentage : " << percentage << "%" << endl;

    if (percentage >= 40)
        cout << "Result     : Pass";
    else
        cout << "Result     : Fail";

    return 0;
}
