#include <iostream>
using namespace std;

int main()
{
    int arr[10], sum = 0;
    float average;

    cout << "Enter 10 elements of the array:\n";
    for(int i = 0; i < 10; i++)
    {
        cin >> arr[i];
        sum += arr[i];
    }

    average = (float)sum / 10;

    cout << "Sum = " << sum << endl;
    cout << "Average = " << average << endl;

    return 0;
}
